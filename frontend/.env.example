# API configuration
# Backend URL for proxy (only used in dev mode)
# Local development: http://localhost:8000
# Production: https://epiassist.onrender.com
VITE_BACKEND_URL=http://localhost:8000

# API base URL for production builds
# Development: /api (uses proxy)
# Production: https://epiassist.onrender.com/api
VITE_API_URL=/api